# Discord
DISCORD_TOKEN=your_discord_bot_token
CLIENT_ID=your_discord_application_id
GUILD_ID=your_guild_id_for_testing

# PostgreSQL (new — replaces Supabase). Self-hosted Postgres 16 + pgvector.
# These POSTGRES_* vars configure `docker compose up` for the database container.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_DB=dsabot
POSTGRES_PORT=5432

# App connection string. Must match the POSTGRES_* values above.
# Use localhost when the bot runs on the same host as the DB container.
DATABASE_URL=postgres://postgres:change_me@localhost:5432/dsabot

# Avatars are stored on the local filesystem (replaces the Supabase Storage bucket).
# Defaults to ./uploads/avatars if unset.
AVATAR_DIR=

# Optional HTTP server (Hono /health + /ready). Defaults to 8080.
PORT=8080

# Website API auth (Discord OAuth2 → JWT). Only needed once the website exists;
# the bot itself doesn't need these (commands call services in-process).
DISCORD_CLIENT_SECRET=your_discord_application_client_secret
JWT_SECRET=generate_a_long_random_string
OAUTH_REDIRECT_URI=https://your-website.example/auth/callback

# OpenAI (for rule embeddings + semantic rules search)
OPENAI_API_KEY=sk-your_openai_api_key

# --- Legacy (Supabase) — removed once Phase 3 rewire is complete ---
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your_anon_key
# SUPABASE_SERVICE_KEY=your_service_role_key
